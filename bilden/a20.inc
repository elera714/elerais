;========================================================================
;
;işlev  : a20_aktiflestir
;tanım  : adres yolunun 20. bitini aktifleştirir
;çıkış  : yok
;
;========================================================================
align 4
a20_aktiflestir:

        ;kesmeleri pasifleştir
        ;----------------------------------------------------------------
        cli

        ;keyboard kontrolleri pasifleştir
        ;----------------------------------------------------------------
        call    giris_hazirmi
        mov     al,0xAD
        out     0x64,al

        ;keyboard kontroller'i oku komutu gönder
        ;----------------------------------------------------------------
        call    giris_hazirmi
        mov     al,0xD0
        out     0x64,al

        ;data'yı oku & sakla
        ;----------------------------------------------------------------
        call    cikis_hazirmi
        in      al,0x60
        push    eax

        ;keyboard kontroller'e yaz komutu gönder
        ;----------------------------------------------------------------
        call    giris_hazirmi
        mov     al,0xD1
        out     0x64,al

        ;okunan data'nın 1. biti'ni (a20 biti) set et ve data'yı gönder
        ;----------------------------------------------------------------
        call    giris_hazirmi
        pop     eax
        or      al,10b
        out     0x60,al

        ;keyboard kontroller'i aktifleştir
        ;----------------------------------------------------------------
        call    giris_hazirmi
        mov     al,0xAE
        out     0x64,al

        ;kontroller'in giriş buffer'ının 0 olmasını bekle
        ;----------------------------------------------------------------
        call    giris_hazirmi

        ;kesmeleri aktifleştir & çık
        ;----------------------------------------------------------------
        sti
        ret

;========================================================================
;
;işlev  : giris_hazirmi
;tanım  : klavye kontrolcüsünün giriş tamponunun hazır olmasını bekler
;         (komut göndermek için)
;çıkış  : yok
;
;========================================================================
align 4
giris_hazirmi:
@@:
        in      al,0x64
        test    al,10b
        jnz     @b
        ret

;========================================================================
;
;işlev  : cikis_hazirmi
;tanım  : klavye kontrolcüsünün çıkış tamponunun hazır olmasını bekler
;         (veri okumak için)
;çıkış  : yok
;
;========================================================================
align 4
cikis_hazirmi:
@@:
        in      al,0x64
        test    al,1b
        jz      @b
        ret