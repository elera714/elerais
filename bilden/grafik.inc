;========================================================================
;
;işlev  : kart_bilgisi_al
;tanım  : grafik kartı genel bilgilerini alır (ver. memory vs)
;giriş  : yok
;çıkış  : BAŞARI : Carry Yok (NC) HATA : Carry (CY)
;
;========================================================================
align 4
kart_bilgisi_al:

        ;bilgilerin yerleştirileceği adres (es:di = 0x800:0)
        ;----------------------------------------------------------------
        push    es
        push    0x800
        pop     es

        xor     di,di
        mov     ax,0x4F00
        int     0x10
        cmp     ax,0x004F
        jz      .success

        ;carry flağını set et & çık
        ;----------------------------------------------------------------
        pop     es
        stc
        ret

.success:

        ;grafik kart bellek miktarını al
        ;----------------------------------------------------------------
        mov     ax,[es:di+0x12]         ;ax = 64K'lık blok sayısı
;        shl     eax,16                  ;eax = byte olarak uzunluk
;        shr     eax,20                  ;eax = MB olarak uzunluk
        mov     [grafik_bellek_uzunlugu],ax

        ;carry flağını temizle & çık
        ;----------------------------------------------------------------
        pop     es
        clc
        ret

;========================================================================
;
;işlev  : mod_bilgisi_al
;tanım  : grafik kart mod bilgilerini alır
;giriş  : yok
;çıkış  : BAŞARI : Carry Yok (NC) HATA : Carry (CY)
;
;========================================================================
align 4
mod_bilgisi_al:

        ;bilgilerin yerleştirileceği adres (es:di = 0x800:0)
        ;----------------------------------------------------------------
        push    es
        push    0x800
        pop     es

        movzx   ecx,word[grafik_ekran_mod]
        xor     di,di
        mov     ax,0x4F01
        int     0x10
        cmp     ax,0x004F
        jz      .success

        ;carry flağını set et & çık
        ;----------------------------------------------------------------
        pop     es
        stc
        ret

.success:

        ;grafik kart lfb addresi
        ;----------------------------------------------------------------
        mov     eax,[es:di+0x28]
        mov     [grafik_bellek_adresi],eax

        ;grafik kart bpp değeri (bpp = bits per pixel)
        ;----------------------------------------------------------------
        movzx   eax,byte[es:di+0x19]
        mov     [grafik_px_basina_bit],al ;eax

        ;grafik kart bpsl değeri (bpsl = bir satırdaki toplam bit sayısı)
        ;----------------------------------------------------------------
        movzx   eax,word[es:di+0x10]
        mov     [grafik_satir_byte_uz],ax

        ;carry flağını temizle & çık
        ;----------------------------------------------------------------
        pop     es
        clc
        ret

;========================================================================
;
;işlev  : mod_bilgisi_yaz
;tanım  : belirtilen mod'da grafiksel ekrana geçer
;giriş  : yok
;çıkış  : BAŞARI : Carry Yok (NC) HATA : Carry (CY)
;
;========================================================================
align 4
mod_bilgisi_yaz:

        ;belirtilen grafik moduna geç
        ;----------------------------------------------------------------
        movzx   ebx,word[grafik_ekran_mod]
        or      ebx,0x4000              ;bit 14 = use lfb
        mov     ax,0x4F02
        int     0x10
        cmp     ax,0x004F
        je      .success

        ;carry flağını set et & çık
        ;----------------------------------------------------------------
        stc
        ret

.success:

        ;carry flağını temizle & çık
        ;----------------------------------------------------------------
        clc
        ret