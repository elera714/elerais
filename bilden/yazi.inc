;========================================================================
;
;işlev  : karakter_yaz
;tanım  : yazı modunda ekrana karakter yazar
;giriş  : al = karakter
;çıkış  : yok
;
;========================================================================
align 4
karakter_yaz:
        mov     ah,0xe
        int     0x10
        ret

;========================================================================
;
;işlev  : yazi_yaz
;tanım  : yazı modunda ekrana karakter katarı değeri yazar
;giriş  : si = string adresi
;çıkış  : yok
;
;========================================================================
align 4
yazi_yaz:
@@:
        lodsb
        or      al,al
        jz      @f
        mov     ah,0x0e
        int     0x10
        jmp     @b
@@:
ret

;========================================================================
;
;işlev  : satirbasi_yap
;tanım  : yazı modunda satır başı yapar
;giriş  : yok
;çıkış  : yok
;
;========================================================================
align 4
satirbasi_yap:
        mov     ax,0x0e0d
        int     0x10
        mov     ax,0x0e0a
        int     0x10
        ret

;========================================================================
;
;işlev  : sayi16_yaz
;tanım  : yazı modunda ekrana 16lı sayı sistemde (hexadesimal) değer yazar
;giriş  : eax = hexadesimal değer, cx = yazılacak hane sayısı (1..8)
;çıkış  : yok
;
;========================================================================
align 4
sayi16_yaz:

        ;yazılacak hane (dijit) sayısını kontrol et (1..8 arası)
        ;----------------------------------------------------------------
        mov     edx,eax
        and     cx,1111b
        cmp     cx,0
        ja      @f
        mov     cx,8
        jmp     .cevir
@@:
        cmp     cx,8
        jbe     .cevir
        mov     cx,8

        ;yazılmayacak haneleri atla
        ;----------------------------------------------------------------
.cevir:
        push    cx
        mov     ax,8
        sub     ax,cx
        mov     cx,ax
        shl     cx,2
        rol     edx,cl
        pop     cx

        ;sayısal değeri ascii değere çevir
        ;----------------------------------------------------------------
.yaz:
        rol     edx,4
        mov     al,dl
        and     al,0xf

        cmp     al,9
        jbe     .D_09
.D_AF:
        add     al,55
        jmp     .ekran
.D_09:
        add     al,48
.ekran:
        mov     ah,0x0e
        int     0x10
        loop    .yaz
        ret